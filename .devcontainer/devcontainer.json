{
  "name": "Crane Blog",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "opam",
  "customizations": {
    "vscode": {
      "extensions": [
        "ocamllabs.ocaml-platform",
        "rocq-prover.vsrocq",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        "shd101wyy.markdown-preview-enhanced",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "ocaml.sandbox": {
          "kind": "opam",
          "switch": "default"
        },
        "vsrocq.path": "/home/opam/.opam/default/bin/vsrocqtop"
      }
    }
  },
  "updateRemoteUserUID": true,
  "postCreateCommand": "sudo chown -R opam:opam . && eval $(opam env) && dune build",
  "runArgs": []
}