#!/usr/bin/env bash
# pre-commit hook -- encrypt any staged posts/*.md into
# posts-encrypted/<slug>.eml, stage the ciphertext, and unstage the
# plaintext. The plaintext never enters a commit.
#
# Crypto is done by gpg. MIME framing and the glue around it are
# built by the OCaml executable tools/encrypt_post, which is part of
# this repo's dune build tree.
set -euo pipefail

repo="$(git rev-parse --show-toplevel)"
cd "$repo"

# Safety net: refuse to commit anything under posts-encrypted/ that is
# not an .eml ciphertext (or the .gitkeep). Catches the case where a
# plaintext file is misplaced directly into posts-encrypted/ and would
# otherwise bypass the encrypt step entirely.
mapfile -t bad < <(
    git diff --cached --name-only --diff-filter=AM -- 'posts-encrypted/*' \
        | grep -Ev '(^posts-encrypted/[^/]+\.eml$|^posts-encrypted/\.gitkeep$)' \
        || true
)
if [[ ${#bad[@]} -gt 0 ]]; then
    echo "pre-commit: refusing to commit non-ciphertext under posts-encrypted/:" >&2
    printf '  %s\n' "${bad[@]}" >&2
    echo "Move plaintext into posts/ (gitignored) and commit from there." >&2
    exit 1
fi

mapfile -t staged < <(
    git diff --cached --name-only --diff-filter=AMR -- 'posts/*.md' || true
)

if [[ ${#staged[@]} -eq 0 ]]; then
    exit 0
fi

if ! command -v dune >/dev/null 2>&1; then
    echo "pre-commit: dune not on PATH; did you 'eval \$(opam env)'?" >&2
    exit 1
fi

dune build tools/encrypt_post.exe
enc="./_build/default/tools/encrypt_post.exe"

for path in "${staged[@]}"; do
    if [[ ! -f "$path" ]]; then
        echo "pre-commit: staged file missing from working tree: $path" >&2
        exit 1
    fi
    "$enc" --stage "$path"
done
